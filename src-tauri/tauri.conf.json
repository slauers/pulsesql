{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PulseSQL",
  "version": "0.1.0",
  "identifier": "com.pulsesql.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "PulseSQL",
        "width": 1180,
        "height": 760,
        "minWidth": 900,
        "minHeight": 620,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDcyNjE5QkRCNTY1NkVCODYKUldTRzYxWlcyNXRoY285dy9WSkJ1Qmg4NXJrdzNqS2Q3TmE5RUpyOVRkNjBteTBLeU9iWGpZT1EK",
      "endpoints": [
        "https://github.com/slauers/pulsesql/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
